# Copy to .env in the repo root (or another path outside git). Never commit real values.
#
# Load into your shell before running serve/watch:
#   set -a && source .env && set +a
#
# Or export variables in your shell profile / launchd EnvironmentVariables block.

# Eero household monitor (optional sibling app)
# EERO_SESSION=
# EERO_NETWORK_ID=

# Main monitor — shared token for agent ingest (optional)
# MONITOR_AGENT_TOKEN=

# Alert webhook override (optional; config.yaml also supports webhook_url)
# ALERT_WEBHOOK_URL=
